@baseUrl = https://sketch3dlab.com
@camionId = 1

###
GET {{baseUrl}}/api/camiones/placas
Accept: application/json

###
GET {{baseUrl}}/api/camiones/placas/paginado?per_page=10&q=ABC
Accept: application/json

###
GET {{baseUrl}}/api/camiones
Accept: application/json

###
POST {{baseUrl}}/api/camiones
Accept: application/json
Content-Type: application/json

{
  "placa": "ABC-123",
  "marca": "Volvo",
  "modelo": "FH16",
  "anio": 2024,
  "capacidad_carga": 20.5,
  "estado": "activo",
  "conductor_asignado": "Juan Perez",
  "observaciones": "Registro desde archivo HTTP producción"
}

###
GET {{baseUrl}}/api/camiones/{{camionId}}
Accept: application/json

###
PUT {{baseUrl}}/api/camiones/{{camionId}}
Accept: application/json
Content-Type: application/json

{
  "placa": "ABC-123",
  "marca": "Volvo",
  "modelo": "FH16 EVO",
  "anio": 2025,
  "capacidad_carga": 21,
  "estado": "mantenimiento",
  "conductor_asignado": "Pedro Alvarez",
  "observaciones": "Actualización desde archivo HTTP producción"
}

###
DELETE {{baseUrl}}/api/camiones/{{camionId}}
Accept: application/json

###
POST {{baseUrl}}/api/camiones/geolocalizaciones
Accept: application/json
Content-Type: application/json

{
  "placa": "ABC-123",
  "latitud": -12.0464,
  "longitud": -77.0428,
  "timestamp": "2026-03-28T10:30:00"
}
